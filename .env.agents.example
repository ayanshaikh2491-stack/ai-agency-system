# ============================================
# 🤖 MANAGED AGENT ORCHESTRATOR CONFIG
# ============================================

# LLM Provider Selection
# Options: groq, openrouter, local, claude
LLM_PROVIDER=groq

# ============================================
# 🟢 GROQ API (FREE & RECOMMENDED)
# ============================================
# Get key: https://console.groq.com/keys
# Sign up: https://console.groq.com (free)
GROQ_API_KEY=gsk_xxxxx

# ============================================
# 🟡 OPENROUTER API (Free tier available)
# ============================================
# Get key: https://openrouter.ai/keys
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-xxxxx

# ============================================
# 🟣 LOCAL LLM (Completely free)
# ============================================
# Setup: ollama pull mistral && ollama serve
LOCAL_LLM_URL=http://localhost:11434

# ============================================
# 🔵 CLAUDE API (Paid - $0.003/1K tokens)
# ============================================
# Get key: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxx

# ============================================
# 🌐 DEPLOYMENT CREDENTIALS
# ============================================
# GitHub Token (for pushing code)
# Get: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxx
GITHUB_USERNAME=your-username

# Vercel Token (for deploying)
# Get: https://vercel.com/account/tokens
VERCEL_TOKEN=vercel_xxxxx
VERCEL_ORG_ID=team_xxxxx
VERCEL_PROJECT_ID=prj_xxxxx

# ============================================
# 📧 EMAIL CONFIGURATION
# ============================================
# Gmail SMTP (for Nodemailer)
# Get app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================
# 🗄️ DATABASE CONFIGURATION
# ============================================
# Supabase (PostgreSQL)
# Get: https://supabase.com/dashboard
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGc...
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ============================================
# 🤖 AGENT CONFIGURATION
# ============================================
# Agent parallel execution
MAX_PARALLEL_AGENTS=6

# LLM request timeout (ms)
LLM_TIMEOUT=30000

# Task queue max retries
MAX_RETRIES=3

# ============================================
# 📊 LOGGING & MONITORING
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry error tracking (optional)
SENTRY_DSN=

# ============================================
# 🔐 SECURITY
# ============================================
# JWT Secret for authentication
JWT_SECRET=your-super-secret-key-change-this

# API Rate limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 🌍 ENVIRONMENT
# ============================================
# development, staging, production
NODE_ENV=production

# Server port
PORT=3000

# ============================================
# 📝 NOTES
# ============================================
# 1. NEVER commit this file to git!
# 2. Copy to .env and fill in your keys
# 3. For production, set keys in CI/CD secrets
# 4. Keep API keys secure - rotate regularly
# 5. Use different keys for dev/staging/prod

# RECOMMENDED SETUP ORDER:
# 1. Set LLM_PROVIDER=groq
# 2. Get free Groq API key
# 3. Set GROQ_API_KEY
# 4. Test: node agent-coordinator.js check
# 5. Deploy: node agent-coordinator.js deploy "My Site"
